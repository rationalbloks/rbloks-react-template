# ============================================================================
# FRONTBLOK ENV
# ============================================================================
# Copy to .env and fill in real values.
# Local dev: VITE_* only. Deployment: all variables.
# Infra secrets (GITHUB_TOKEN, DEPLOY_REGISTRY) live on the VPS only.
# ============================================================================


# ============================================================================
# DEPLOYMENT
# ============================================================================

DEPLOY_DOMAIN=app.example.com
# DEPLOY_VPS_ENV_PATH=/etc/businessblok/.env


# ============================================================================
# VITE BUILD VARIABLES
# ============================================================================

VITE_DATABASE_API_URL=https://api.example.com
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
